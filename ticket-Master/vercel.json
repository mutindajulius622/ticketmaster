{
    "version": 2,
    "builds": [
        {
            "src": "backend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "backend/api/index.py"
        },
        {
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/favicon.ico"
        },
        {
            "src": "/manifest.json",
            "dest": "/manifest.json"
        },
        {
            "src": "/admin.*",
            "dest": "/index.html"
        },
        {
            "src": "/login",
            "dest": "/index.html"
        },
        {
            "src": "/dashboard",
            "dest": "/index.html"
        },
        {
            "src": "/search",
            "dest": "/index.html"
        },
        {
            "src": "/saved-events",
            "dest": "/index.html"
        },
        {
            "src": "/profile",
            "dest": "/index.html"
        },
        {
            "src": "/checkout/(.*)",
            "dest": "/index.html"
        },
        {
            "src": "/events/(.*)",
            "dest": "/index.html"
        },
        {
            "src": "/venues/(.*)/seatmap",
            "dest": "/index.html"
        },
        {
            "src": "/",
            "dest": "/index.html"
        }
    ],
    "env": {
        "FLASK_ENV": "production",
        "PYTHON_VERSION": "3.9"
    }
}