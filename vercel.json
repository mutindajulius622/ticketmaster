{
    "version": 2,
    "builds": [
        {
            "src": "ticket-Master/backend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "ticket-Master/frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "ticket-Master/backend/api/index.py"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "ticket-Master/backend/api/index.py"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "env": {
        "FLASK_ENV": "production",
        "PYTHON_VERSION": "3.9"
    }
}