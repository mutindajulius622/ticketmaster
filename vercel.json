{
    "version": 2,
    "builds": [
        {
            "src": "ticket-Master/backend/api/index.py",
            "use": "@vercel/python"
        },
        {
            "src": "ticket-Master/frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/ticket-Master/backend/api/index.py"
        },
        {
            "source": "/uploads/:path*",
            "destination": "/ticket-Master/backend/api/index.py"
        },
        {
            "source": "/static/:path*",
            "destination": "/ticket-Master/frontend/static/:path*"
        },
        {
            "source": "/asset-manifest.json",
            "destination": "/ticket-Master/frontend/asset-manifest.json"
        },
        {
            "source": "/((?!api|uploads|static).*)",
            "destination": "/ticket-Master/frontend/index.html"
        }
    ],
    "env": {
        "FLASK_ENV": "production",
        "PYTHON_VERSION": "3.9"
    }
}